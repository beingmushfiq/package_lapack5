APP_NAME=AmarShop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=package_lapack5_db
DB_USERNAME=root
DB_PASSWORD=

# ── Session ───────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Services ──────────────────────────────────────
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Filesystem ────────────────────────────────────
# Use 'local' for local disk, 'public' for public disk, or 's3' for AWS S3
FILESYSTEM_DISK=public

# If using S3, fill in these values:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=amarshop-assets
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail ──────────────────────────────────────────
# For development, use 'log' to write emails to logs.
# For production, use 'smtp' with a real provider (Mailgun, SES, etc.)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@amarshop.com.bd"
MAIL_FROM_NAME="${APP_NAME}"

# Example SMTP (Gmail/Mailgun):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=postmaster@mg.yourdomain.com
# MAIL_PASSWORD=your-mailgun-password
# MAIL_ENCRYPTION=tls

# ── Redis (optional) ─────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Frontend URL (for CORS) ──────────────────────
FRONTEND_URL=http://localhost:5173

VITE_APP_NAME="${APP_NAME}"
